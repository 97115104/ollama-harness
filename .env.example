# Inference Studio environment configuration
# Copy this file to .env and edit as needed

# Admin credentials (change password in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# JWT signing secret — change to a long random string
JWT_SECRET=inference-studio-change-me-in-production

# Optional: Hugging Face token (needed for gated models like Llama)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
